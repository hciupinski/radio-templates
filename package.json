{
  "name": "radio-templates",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:content": "node scripts/generate-content.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "dev": "npm run generate:content && vite --host 127.0.0.1",
    "validate": "node scripts/validate-content.mjs",
    "build": "npm run generate:content && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "export:pdf": "npm run build && node scripts/export-pdf.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "fuse.js": "^7.1.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.468.0",
    "playwright": "^1.57.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
